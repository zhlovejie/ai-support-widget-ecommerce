# MongoDB connection string (local or MongoDB Atlas free tier)
MONGODB_URI=mongodb://127.0.0.1:27017/ai_support_demo

# Choose your LLM provider: "openai", "anthropic", or "deepseek"
LLM_PROVIDER=openai

# OpenAI (if LLM_PROVIDER=openai)
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_MODEL=gpt-4o-mini

# Anthropic (if LLM_PROVIDER=anthropic)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx
ANTHROPIC_MODEL=claude-sonnet-4-6

# DeepSeek (if LLM_PROVIDER=deepseek)
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_THINKING=disabled

# Runtime safeguards
LLM_TIMEOUT_MS=30000
LLM_MAX_TOKENS=400
CHAT_RATE_LIMIT_WINDOW_MS=60000
CHAT_RATE_LIMIT_MAX=10

PORT=4000
